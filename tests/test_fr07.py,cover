> """FR-07: Knowledge Layer V1 — Rule Match + Escalate.
  
> [FR-07] Acceptance criteria:
>   - Query knowledge base with exact/fuzzy SQL match
>   - Confidence > 0.7 returns match with reply
>   - Confidence <= 0.7 escalates to human
  
> Citations: SRS.md FR-07 section
> """
  
> from omnibot.knowledge import KnowledgeBase, QueryResult, query_knowledge
  
  
> def test_exact_match_high_confidence():
>     """High keyword coverage returns confidence > 0.7."""
>     kb = KnowledgeBase()
>     kb.add_rule(keywords=["退貨"], response="退貨流程：請提供訂單編號...")
>     result = kb.query("我要退貨")
>     assert result.confidence > 0.7
>     assert "退貨" in result.response
  
  
> def test_no_match_low_confidence():
>     """Unmatched query returns confidence <= 0.7 and escalates."""
>     kb = KnowledgeBase()
>     kb.add_rule(keywords=["退貨"], response="退貨流程")
>     result = kb.query("今天天氣如何")
>     assert result.confidence <= 0.7
>     assert result.escalate is True
  
  
> def test_partial_match_fuzzy():
>     """Partial keyword overlap gives moderate confidence <= 0.7."""
>     kb = KnowledgeBase()
>     kb.add_rule(keywords=["訂單", "查詢"], response="請提供訂單編號")
>     result = kb.query("訂單")
>     assert result.confidence > 0
  
  
> def test_multiple_rules_best_match():
>     """Multiple rules — best matching rule is returned."""
>     kb = KnowledgeBase()
>     kb.add_rule(keywords=["退貨"], response="退貨流程")
>     kb.add_rule(keywords=["訂單", "查詢"], response="訂單查詢流程")
>     result = kb.query("我想查詢訂單狀態")
>     assert "訂單" in result.response
  
  
> def test_query_result_dataclass():
>     """QueryResult has response, confidence, source, escalate fields."""
>     r = QueryResult(response="test", confidence=0.9, source="rule_match", escalate=False)
>     assert r.response == "test"
>     assert r.confidence == 0.9
>     assert r.source == "rule_match"
>     assert r.escalate is False
  
  
> def test_convenience_function():
>     """query_knowledge() convenience function works."""
>     result = query_knowledge("退貨查詢")
>     assert isinstance(result, QueryResult)
