> """FR-09: Structured Logger — JSON Format.
  
> [FR-09] Acceptance criteria:
>   - NDJSON: one JSON line per log entry
>   - Required fields: timestamp (ISO 8601 UTC), level, service, message
>   - Extra kwargs appear as fields
>   - Five levels: DEBUG, INFO, WARN, ERROR, CRITICAL
>   - Shorthand methods: debug(), info(), warn(), error(), critical()
  
> Citations: SRS.md FR-09 section, SAD.md 2.6.1 StructuredLogger
> """
  
> import json
> import sys
> import io
> from datetime import datetime
  
> from omnibot.logger import StructuredLogger
  
  
> def _capture(logger, method, *args, **kwargs):
>     """Capture a single log call, redirecting stdout."""
>     old_stdout = sys.stdout
>     sys.stdout = io.StringIO()
>     try:
>         getattr(logger, method)(*args, **kwargs)
>         return sys.stdout.getvalue()
>     finally:
>         sys.stdout = old_stdout
  
  
> def test_log_output_is_valid_json():
>     """Each log call produces a single valid JSON line."""
>     logger = StructuredLogger(service="test")
>     out = _capture(logger, "info", message="hello")
>     parsed = json.loads(out.strip())
>     assert isinstance(parsed, dict)
  
  
> def test_log_output_is_single_line():
>     """Each log call outputs exactly one line (NDJSON)."""
>     logger = StructuredLogger(service="test")
>     out = _capture(logger, "info", message="hello")
>     assert out.count("\n") == 1
>     assert not out.startswith("\n")
  
  
> def test_required_fields():
>     """Output contains timestamp, level, service, message."""
>     logger = StructuredLogger(service="omnibot")
>     out = _capture(logger, "info", message="test message")
>     parsed = json.loads(out.strip())
>     assert "timestamp" in parsed
>     assert "level" in parsed
>     assert "service" in parsed
>     assert parsed["service"] == "omnibot"
>     assert parsed["message"] == "test message"
  
  
> def test_timestamp_is_iso8601_utc():
>     """Timestamp field is ISO 8601 UTC with Z suffix."""
>     logger = StructuredLogger(service="test")
>     out = _capture(logger, "warn", message="ts test")
>     parsed = json.loads(out.strip())
>     ts = parsed["timestamp"]
>     assert ts.endswith("Z") or "+00:00" in ts
      # parseable as UTC datetime
>     dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
>     assert dt.tzinfo is not None
  
  
> def test_kwargs_as_extra_fields():
>     """Additional kwargs appear as top-level JSON fields."""
>     logger = StructuredLogger(service="test")
>     out = _capture(logger, "info", message="matched", confidence=0.95, source="rule")
>     parsed = json.loads(out.strip())
>     assert parsed["confidence"] == 0.95
>     assert parsed["source"] == "rule"
  
  
> def test_level_info():
>     """info() sets level=INFO."""
>     out = _capture(StructuredLogger(service="s"), "info", message="m")
>     assert json.loads(out.strip())["level"] == "INFO"
  
  
> def test_level_warn():
>     """warn() sets level=WARN."""
>     out = _capture(StructuredLogger(service="s"), "warn", message="m")
>     assert json.loads(out.strip())["level"] == "WARN"
  
  
