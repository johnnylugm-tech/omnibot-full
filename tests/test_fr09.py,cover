> def test_different_service_name():
>     """Service name is configurable."""
>     out = _capture(StructuredLogger(service="adapter"), "info", message="m")
>     assert json.loads(out.strip())["service"] == "adapter"
  
  
> def test_log_method_accepts_level_string():
>     """log() method accepts a level string directly."""
>     logger = StructuredLogger(service="test")
>     out = _capture(logger, "log", level="INFO", service="test2", message="direct")
>     parsed = json.loads(out.strip())
>     assert parsed["level"] == "INFO"
>     assert parsed["service"] == "test2"
>     assert parsed["message"] == "direct"
