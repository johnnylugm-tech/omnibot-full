> def test_build_sandwich_prompt_structure():
>     """Sandwich prompt has the required section headers in order."""
>     defense = PromptInjectionDefense()
>     prompt = defense.build_sandwich_prompt(
>         system_instruction="You are a helpful assistant.",
>         user_input="What time is it?",
>         context="The user is in Tokyo.",
>     )
>     assert "[SYSTEM INSTRUCTION]" in prompt
>     assert "[RETRIEVED CONTEXT]" in prompt
>     assert "[USER MESSAGE]" in prompt
>     assert "[SYSTEM REMINDER]" in prompt
      # Verify order: SYSTEM INSTRUCTION before CONTEXT before USER MESSAGE before SYSTEM REMINDER
>     si_pos = prompt.index("[SYSTEM INSTRUCTION]")
>     rc_pos = prompt.index("[RETRIEVED CONTEXT]")
>     um_pos = prompt.index("[USER MESSAGE]")
>     sr_pos = prompt.index("[SYSTEM REMINDER]")
>     assert si_pos < rc_pos < um_pos < sr_pos
  
  
