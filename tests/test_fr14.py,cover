> def test_messenger_webhook_valid_signature_and_parse():
>     """POST with valid Messenger HMAC signature returns 200 and parses correctly."""
>     body = json.dumps(MESSENGER_WEBHOOK_PAYLOAD).encode()
>     response = client.post(
>         "/api/v1/webhook/messenger",
>         content=body,
>         headers=_messenger_headers(body),
>     )
>     assert response.status_code == 200
>     data = response.json()
>     assert data["platform"] == "MESSENGER"
>     assert data["platform_user_id"] == "987654321098765"
>     assert data["message_type"] == "TEXT"
>     assert data["content"] == "Hello from Messenger!"
>     assert "received_at" in data
  
  
> def test_messenger_webhook_response_time():
>     """Messenger webhook responds within 3 seconds."""
>     body = json.dumps(MESSENGER_WEBHOOK_PAYLOAD).encode()
>     headers = _messenger_headers(body)
>     start = time.monotonic()
>     client.post("/api/v1/webhook/messenger", content=body, headers=headers)
>     elapsed = time.monotonic() - start
>     assert elapsed < 3.0
  
  
