  # ── Helpers ───────────────────────────────────────────────────────────────────
  
> def compute_hub_signature(app_secret: str, body: bytes) -> str:
>     """Compute sha256= + HMAC-SHA256 signature for Messenger/WhatsApp."""
>     digest = hmac.new(app_secret.encode(), body, hashlib.sha256).hexdigest()
>     return f"sha256={digest}"
  
  
> MESSENGER_APP_SECRET = "messenger_app_secret_abc123"
> WHATSAPP_APP_SECRET = "whatsapp_app_secret_xyz789"
  
> MESSENGER_WEBHOOK_PAYLOAD = {
>     "object": "page",
>     "entry": [{
>         "id": "123456789012345",
>         "time": 1458692752478,
>         "messaging": [{
>             "sender": {"id": "987654321098765"},
>             "recipient": {"id": "123456789012345"},
>             "timestamp": 1458692752478,
>             "message": {
>                 "mid": "mid.1457764197618:41d102a3e1ae206a38",
>                 "text": "Hello from Messenger!",
>             },
>         }],
>     }],
> }
  
> WHATSAPP_WEBHOOK_PAYLOAD = {
