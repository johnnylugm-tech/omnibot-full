>                 "metadata": {
>                     "display_phone_number": "+1 555 123 4567",
>                     "phone_number_id": "222222222222222",
>                 },
>                 "contacts": [{
>                     "profile": {"name": "John Doe"},
>                     "wa_id": "333333333333333",
>                 }],
>                 "messages": [{
>                     "from": "333333333333333",
>                     "id": "wamid.abc123def456",
>                     "timestamp": "1700000000",
>                     "text": {"body": "Hello from WhatsApp!"},
>                     "type": "text",
>                 }],
>             },
>             "field": "messages",
>         }],
>     }],
> }
  
  
> def _messenger_headers(body: bytes, app_secret: str = MESSENGER_APP_SECRET) -> dict:
>     return {
>         "Content-Type": "application/json",
>         "X-Messenger-App-Secret": app_secret,
>         "X-Hub-Signature-256": compute_hub_signature(app_secret, body),
>     }
  
  
> def _whatsapp_headers(body: bytes, app_secret: str = WHATSAPP_APP_SECRET) -> dict:
