>             return KnowledgeResult(
>                 id=-1,
>                 query=query,
>                 response="",
>                 confidence=0.0,
>                 source="escalate",
>             )
  
          # Build context from RRF results
>         if context_results:
>             context_text = "\n".join(
>                 f"Q: {r.query}\nA: {r.response}" for r in context_results
>             )
>         else:
>             context_text = "No relevant context available."
  
